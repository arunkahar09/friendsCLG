<!DOCTYPE html>
<html lang="en" class="scroll-smooth">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Friends - The Portfolio Vibe</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-dark': '#0a0a0c',
                        'brand-panel': '#111114',
                        'brand-accent': '#ef4444',
                        'text-faded': '#d4d4d8'
                    },
                    spacing: {
                        'panel-pad': '6rem'
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-brand-dark text-text-faded font-sans overflow-x-hidden antialiased">

    <section
        class="min-h-screen flex flex-col justify-center items-center relative border-b border-zinc-900 bg-black/40">
        <div class="absolute inset-0 z-1 flex justify-center items-center pointer-events-none opacity-10">
            <div class="w-[600px] h-[600px] bg-brand-accent rounded-full blur-[200px]"></div>
        </div>

        <div class="relative z-10 text-center px-6" data-aos="zoom-in" data-aos-duration="1500">
            <p class="text-sm uppercase tracking-widest text-brand-accent mb-3 font-semibold">Special Edition</p>
            <h1 class="text-6xl md:text-8xl font-black text-white leading-tight tracking-tighter mb-4">
                Memory <span class="text-zinc-600">Sync</span>
            </h1>
            <h2 class="text-xl md:text-2xl text-zinc-400 font-medium max-w-2xl mx-auto leading-relaxed">
                A digital archive dedicated to the people who make life extraordinary. Scrolling through time, one
                friend at a time.
            </h2>
            <p class="text-sm text-zinc-500 mt-12 italic">Keep scrolling for the roster...</p>
        </div>
    </section>

    <main class="container mx-auto relative z-10">
        <% friends.forEach((friend, index)=> { %>

            <section
                class="min-h-screen flex items-center justify-center relative py-panel-pad border-b border-zinc-950/40">

                <div
                    class="w-full max-w-7xl px-8 flex flex-col md:<%= index % 2 === 0 ? 'flex-row' : 'flex-row-reverse' %> items-center gap-16 md:gap-24">

                    <div class="w-full md:w-1/2 flex justify-center relative p-4"
                        data-aos="<%= index % 2 === 0 ? 'fade-right' : 'fade-left' %>" data-aos-duration="1200"
                        data-aos-delay="100">

                        <div
                            class="relative group aspect-[4/3] w-full max-w-lg overflow-hidden rounded-xl border border-zinc-800 shadow-[0_30px_90px_rgba(0,0,0,0.6)]">
                            <img src="/Images/home2/<%= friend.image %>"
                                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 group-hover:blur-sm">

                            <div
                                class="absolute inset-x-8 bottom-8 z-10 p-6 rounded-lg bg-brand-panel/90 border border-zinc-800 opacity-0 transform translate-y-6 transition-all duration-500 group-hover:opacity-100 group-hover:translate-y-0 shadow-lg">
                                <h3 class="text-lg font-bold text-white mb-2">
                                    <%= friend.name %>
                                </h3>
                                <p class="text-xs text-zinc-500 italic">Established Memory <%= index + 1 %>
                                </p>
                            </div>
                        </div>

                    </div>

                    <div class="w-full md:w-1/2 text-center <%= index % 2 === 0 ? 'md:text-left' : 'md:text-right' %> flex flex-col items-center <%= index % 2 === 0 ? 'md:items-start' : 'md:items-end' %>"
                        data-aos="<%= index % 2 === 0 ? 'fade-left' : 'fade-right' %>" data-aos-duration="1400"
                        data-aos-delay="300">

                        <p class="text-xs uppercase tracking-[0.4em] text-zinc-600 mb-5 font-medium">Memory Dossier // 0
                            <%= index + 1 %>
                        </p>

                        <h2 class="text-5xl font-black text-white leading-tight tracking-tighter mb-8 group">
                            <%= friend.name %>
                                <span
                                    class="block h-1 w-24 bg-brand-accent mt-3 transition-all duration-500 scale-x-0 origin-left group-hover:scale-x-100 <%= index % 2 === 0 ? '' : 'origin-right' %>"></span>
                        </h2>

                        <div class="bg-brand-panel p-8 rounded-2xl border border-zinc-900 shadow-inner max-w-lg w-full">
                            <p class="text-lg md:text-xl text-zinc-300 leading-relaxed font-light italic">
                                "<%= friend.desc %>"
                            </p>
                        </div>

                        <p class="absolute bottom-10 <%= index % 2 === 0 ? 'left-10' : 'right-10' %> text-sm text-zinc-800 font-black tracking-widest p-2 bg-brand-panel/40 rounded-full select-none"
                            data-aos="fade-up">
                            0<%= index + 1 %> / <%= friends.length %>
                        </p>
                    </div>

                </div>

            </section>
            <% }) %>
    </main>
    
    <div class="fixed bottom-10 right-10 z-50" data-aos="fade-left" data-aos-delay="1000">
        <a href="/gallery"
            class="group relative flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-white rounded-full shadow-[0_20px_50px_rgba(225,29,72,0.3)] transition-all duration-500 hover:scale-110 active:scale-95">
            <span
                class="text-black text-[10px] md:text-xs font-black uppercase tracking-tighter group-hover:rotate-12 transition-transform">
                Gallery
            </span>
            <div
                class="absolute inset-0 rounded-full border border-white/20 scale-125 group-hover:scale-150 group-hover:opacity-0 transition-all duration-700">
            </div>
            <div
                class="absolute inset-0 bg-brand-red/20 blur-xl rounded-full -z-10 opacity-0 group-hover:opacity-100 transition-opacity">
            </div>
        </a>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            offset: 200,
            delay: 0,
            duration: 1200,
            easing: 'ease-out-cubic',
            once: false,
            mirror: true,
        });
    </script>
</body>

</html>